FROM bitnami/pgpool:4.6.2-debian-12-r1

USER 0

RUN mkdir -p /app /data/.claude /workspace \
  && chown -R 1001:0 /app /data /workspace

COPY --chown=1001:0 deploy/100server/offline/claude-sidecar /app/claude-sidecar
COPY --chown=1001:0 deploy/100server/offline/web /app/dist

RUN chmod 755 /app/claude-sidecar

USER 1001
WORKDIR /workspace

ENV HOME=/opt/bitnami \
  CLAUDE_CONFIG_DIR=/data/.claude \
  CLAUDE_APP_ROOT=/app \
  CLAUDE_CLI_PATH=/app/claude-sidecar \
  CLAUDE_H5_DIST_DIR=/app/dist

ENTRYPOINT ["/app/claude-sidecar"]
